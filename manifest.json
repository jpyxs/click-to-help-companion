{
  "manifest_version": 3,
  "name": "Click to Help Companion",
  "version": "1.0.0",
  "description": "Automates and tracks your daily clicks for Arab.org's Click-to-Help Palestine campaign.",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],

  "host_permissions": [
    "https://arab.org/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Click to Help Companion"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://arab.org/click-to-help/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
